# =========================
# Node / Next.js
# =========================
node_modules/
.next/
dist/
out/
.vercel/

# =========================
# Environment variables (NEVER COMMIT)
# =========================
.env
.env.*
!.env.example

# =========================
# Logs
# =========================
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# =========================
