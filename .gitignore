# =========================
android/.idea/
android/.gradle/
android/**/build/
android/local.properties
*.iml

# =========================
# iOS / Xcode (future-proof)
# =========================
ios/DerivedData/
ios/Pods/
ios/*.xcworkspace
ios/*.xcuserstate
ios/.DS_Store

# =========================
# OS junk
# =========================
.DS_Store
Thumbs.db

# =========================
# Editor / tooling
# =========================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json